# AI-Forge environment template
# Copy to .env and fill in your values before running the stack.
# Never commit .env with real credentials.

# ---------------------------------------------------------------------------
# PostgreSQL (MLflow metadata store)
# ---------------------------------------------------------------------------
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mlflow
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# MinIO (S3-compatible artifact store)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
MLFLOW_PORT=5000
MLFLOW_ARTIFACT_ROOT=s3://mlflow/

# ---------------------------------------------------------------------------
# Service ports
# ---------------------------------------------------------------------------
TRAIN_PORT=6006
INFER_PORT=8000
UI_PORT=3000

# ---------------------------------------------------------------------------
# Monitoring (Grafana + Loki)
# ---------------------------------------------------------------------------
GRAFANA_PORT=3001
GRAFANA_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Claude VLM backend (M8 — optional)
# Set BACKEND=claude to use Claude instead of the MLflow-registered YOLO model.
# ---------------------------------------------------------------------------
BACKEND=mlflow
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# API authentication (L1/L2 — optional)
# Leave empty to disable auth (suitable for local development).
# Admin key: required to call POST /api/v1/detect.
# Viewer key: accepted on future read-only endpoints.
# ---------------------------------------------------------------------------
INFERENCE_ADMIN_KEY=
INFERENCE_VIEWER_KEY=

# ---------------------------------------------------------------------------
# MinIO artifact retention (L7)
# Number of days after which MLflow artifacts are automatically expired.
# ---------------------------------------------------------------------------
ARTIFACT_RETENTION_DAYS=90
